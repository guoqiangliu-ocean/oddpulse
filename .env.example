# TxLINE credentials are obtained only after a Solana devnet/mainnet subscription
# and token activation. Never expose either value to browser code.
TXLINE_BASE_URL=https://txline-dev.txodds.com
TXLINE_NETWORK=devnet
TXLINE_API_TOKEN=
# Optional: the adapter normally obtains and refreshes guest JWTs automatically.
TXLINE_SESSION_JWT=
# Optional read-only Solana RPC override for odds-proof simulation.
TXLINE_RPC_URL=https://api.devnet.solana.com
# Optional public fee-payer field for sigVerify:false simulation; never signs.
TXLINE_VIEW_PAYER=
