{
  "name": "oddpulse-agent",
  "version": "0.1.0",
  "description": "Authenticated TxLINE Devnet snapshots and device-local audit history, with a clearly separated deterministic replay for explainable football-odds movement analysis.",
  "private": true,
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/guoqiangliu-ocean/oddpulse.git"
  },
  "homepage": "https://oddpulse-agent.oddpulse-txline-2026.workers.dev/",
  "keywords": [
    "txline",
    "txodds",
    "football-odds",
    "sports-data",
    "odds-monitoring",
    "devnet",
    "indexeddb",
    "explainable-analytics"
  ],
  "engines": {
    "node": ">=22.13.0"
  },
  "scripts": {
    "dev": "node scripts/vinext.mjs dev",
    "build": "node scripts/vinext.mjs build",
    "start": "node scripts/vinext.mjs start",
    "test": "npm run build && node --test tests/signal-engine.test.ts tests/snapshot-history.test.ts tests/rendered-html.test.mjs",
    "lint": "eslint . --ignore-pattern dist --ignore-pattern .next",
    "db:generate": "drizzle-kit generate"
  },
  "dependencies": {
    "drizzle-orm": "0.45.2",
    "next": "16.2.6",
    "react": "19.2.6",
    "react-dom": "19.2.6"
  },
  "devDependencies": {
    "@cloudflare/vite-plugin": "1.37.1",
    "@tailwindcss/postcss": "4.2.1",
    "@types/node": "22.19.19",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "6.0.2",
    "@vitejs/plugin-rsc": "0.5.26",
    "drizzle-kit": "0.31.10",
    "eslint": "9.39.4",
    "eslint-config-next": "16.2.6",
    "react-server-dom-webpack": "19.2.6",
    "tailwindcss": "4.2.1",
    "typescript": "5.9.3",
    "vinext": "0.0.50",
    "vite": "8.0.13",
    "wrangler": "4.92.0"
  },
  "type": "module"
}
